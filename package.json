{
  "name": "chaos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "node scripts/build-electron.js",
    "electron:dev": "npm run build:electron && electron .",
    "electron:build": "npm run build:electron && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.neocity.chaos",
    "productName": "CHAOS",
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "files": [
      "dist-electron/**/*",
      "electron/**/*"
    ]
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-unity-webgl": "^10.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}